set shell := ["bash", "-c"]

# Format C files in App and Driver directories with clang-format
format:
    @command -v clang-format >/dev/null 2>&1 || { echo "Error: clang-format not found." >&2; exit 1; }
    @echo "Formatting C files..."
    @find ../App ../Driver -type f \( -name "*.c" -o -name "*.h" \) -exec clang-format -i --style=file:../tools/code.clang-format {} \;
    @echo "Formatting complete!"

# Build the Keil project and copy build log
build:
    @rm -f ../Project/Output/gh32h759temple.build_log.htm ../build_log.htm
    UV4 -b ../Project/gd32h759temple.uvprojx -j0
    @for i in {1..60}; do if [ -f ../Project/Output/gh32h759temple.build_log.htm ] && grep -q 'Error(s)' ../Project/Output/gh32h759temple.build_log.htm; then break; fi; sleep 0.5; done
    @cp ../Project/Output/gh32h759temple.build_log.htm ../build_log.htm
    @echo "Build log copied to ../build_log.htm"

# Rebuild (clean + build) the Keil project
rebuild:
    @rm -f ../Project/Output/gh32h759temple.build_log.htm ../build_log.htm
    UV4 -r ../Project/gd32h759temple.uvprojx -j0
    @for i in {1..60}; do if [ -f ../Project/Output/gh32h759temple.build_log.htm ] && grep -q 'Error(s)' ../Project/Output/gh32h759temple.build_log.htm; then break; fi; sleep 0.5; done
    @cp ../Project/Output/gh32h759temple.build_log.htm ../build_log.htm
    @echo "Build log copied to ../build_log.htm"

# Show errors from the build log
errors:
    @if [ -f ../build_log.htm ]; then grep -i 'error' ../build_log.htm; else echo "No build_log.htm found."; fi

# Show warnings from the build log
warnings:
    @if [ -f ../build_log.htm ]; then grep -i 'warning' ../build_log.htm; else echo "No build_log.htm found."; fi

# Output directory for signed binaries
out_dir := "../Output"

# Convert .axf to .bin and sign with MCUBoot imgtool
sign version="1.0.0":
    @mkdir -p {{out_dir}}
    @echo "Converting .axf to .bin..."
    fromelf --bin --output {{out_dir}}/app_unsigned.bin ../Project/Output/gh32h759temple.axf
    @echo "Signing with ECDSA-P256..."
    python ../gd32h759boot/mcuboot/scripts/imgtool.py sign \
        --key ../gd32h759boot/keys/ecdsa256.pem \
        --align 8 \
        --header-size 0x200 \
        --slot-size 0xA0000 \
        --pad \
        --version {{version}} \
        {{out_dir}}/app_unsigned.bin \
        {{out_dir}}/app_signed.bin
    @echo "Signed binary: {{out_dir}}/app_signed.bin"
    @ls -la {{out_dir}}/app_signed.bin

# Build and sign in one step
release version="1.0.0": (build) (sign version)

# Clean build output files
clean:
    @rm -f ../Project/Output/*.o ../Project/Output/*.d ../Project/Output/*.axf ../Project/Output/*.htm ../Project/Output/*.hex ../Project/Output/*.lnp ../build_log.htm
    @rm -rf {{out_dir}}
    @echo "Clean done."
