set shell := ["bash", "-c"]

outdir := "../Output"
logdir := "../Output/log"

# Format C files in App and Driver directories with clang-format
format:
    @command -v clang-format >/dev/null 2>&1 || { echo "Error: clang-format not found." >&2; exit 1; }
    @echo "Formatting C files..."
    @find ../App ../Driver -type f \( -name "*.c" -o -name "*.h" \) -exec clang-format -i --style=file:../tools/code.clang-format {} \;
    @echo "Formatting complete!"

# Build the Keil project and copy outputs to Output directory
build:
    @rm -f ../Project/Output/gh32h759temple.build_log.htm
    UV4 -b ../Project/gd32h759temple.uvprojx -j0
    @for i in {1..60}; do if [ -f ../Project/Output/gh32h759temple.build_log.htm ] && grep -q 'Error(s)' ../Project/Output/gh32h759temple.build_log.htm; then break; fi; sleep 0.5; done
    @mkdir -p {{logdir}}
    @cp ../Project/Output/gh32h759temple.build_log.htm {{logdir}}/
    @cp ../Project/Output/gh32h759temple.hex {{outdir}}/ 2>/dev/null || true
    @cp ../Project/Output/gh32h759temple.axf {{outdir}}/ 2>/dev/null || true
    @echo "Outputs copied to {{outdir}}/, build log saved to {{logdir}}/"

# Rebuild (clean + build) the Keil project
rebuild:
    @rm -f ../Project/Output/gh32h759temple.build_log.htm
    UV4 -r ../Project/gd32h759temple.uvprojx -j0
    @for i in {1..60}; do if [ -f ../Project/Output/gh32h759temple.build_log.htm ] && grep -q 'Error(s)' ../Project/Output/gh32h759temple.build_log.htm; then break; fi; sleep 0.5; done
    @mkdir -p {{logdir}}
    @cp ../Project/Output/gh32h759temple.build_log.htm {{logdir}}/
    @cp ../Project/Output/gh32h759temple.hex {{outdir}}/ 2>/dev/null || true
    @cp ../Project/Output/gh32h759temple.axf {{outdir}}/ 2>/dev/null || true
    @echo "Outputs copied to {{outdir}}/, build log saved to {{logdir}}/"

# Show errors from the build log
errors:
    @if [ -f {{logdir}}/gh32h759temple.build_log.htm ]; then grep -i 'error' {{logdir}}/gh32h759temple.build_log.htm; else echo "No errors found or build log does not exist."; fi

# Show warnings from the build log
warnings:
    @if [ -f {{logdir}}/gh32h759temple.build_log.htm ]; then grep -i 'warning' {{logdir}}/gh32h759temple.build_log.htm; else echo "No warnings found or build log does not exist."; fi

# Convert .axf to .bin and sign with MCUBoot imgtool
sign version="1.0.0":
    @mkdir -p {{outdir}}
    @echo "Converting .axf to .bin..."
    fromelf --bin --output {{outdir}}/app_unsigned.bin {{outdir}}/gh32h759temple.axf
    @echo "Signing with ECDSA-P256..."
    python ../../gd32h759boot/mcuboot/scripts/imgtool.py sign \
        --key ../../gd32h759boot/keys/ecdsa256.pem \
        --align 8 \
        --header-size 0x200 \
        --pad-header \
        --slot-size 0xA0000 \
        --pad \
        --version {{version}} \
        {{outdir}}/app_unsigned.bin \
        {{outdir}}/app_signed.bin
    @echo "Signed binary: {{outdir}}/app_signed.bin"
    @ls -la {{outdir}}/app_signed.bin

# Build and sign in one step
release version="1.0.0": (build) (sign version)

# Clean build output files
clean:
    @rm -f ../Project/Output/*.o ../Project/Output/*.d ../Project/Output/*.axf ../Project/Output/*.htm ../Project/Output/*.hex ../Project/Output/*.lnp
    @rm -rf {{outdir}}
    @echo "Clean done."
